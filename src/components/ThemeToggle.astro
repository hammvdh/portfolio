---
// shadcn-style theme switch: [sun] [pill] [moon].
// Each icon is its own clickable target that explicitly sets its mode.
// The pill toggles between modes. Reads/writes data-theme on <html> and
// dispatches a 'themechange' CustomEvent.
---

<div class="theme-switch group" role="group" aria-label="Toggle color theme">
  <button
    type="button"
    class="theme-icon-btn theme-icon-sun"
    data-theme-set="light"
    aria-label="Switch to light theme"
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" />
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
    </svg>
  </button>

  <button
    type="button"
    class="theme-pill"
    role="switch"
    aria-checked="false"
    aria-label="Toggle color theme"
  >
    <span class="theme-pill-thumb" aria-hidden="true"></span>
  </button>

  <button
    type="button"
    class="theme-icon-btn theme-icon-moon"
    data-theme-set="dark"
    aria-label="Switch to dark theme"
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </button>
</div>

<style>
  .theme-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .theme-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    padding: 0;
    background: transparent;
    border: 0;
    color: var(--fg);
    cursor: pointer;
    border-radius: 4px;
    transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
  }
  .theme-icon-btn:hover { color: var(--accent); }
  .theme-icon-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Dim the icon for the mode that's NOT active */
  :global([data-theme="dark"]) .theme-icon-sun {
    color: color-mix(in oklab, var(--fg) 50%, transparent);
  }
  :global([data-theme="light"]) .theme-icon-moon {
    color: color-mix(in oklab, var(--fg) 50%, transparent);
  }

  .theme-pill {
    --pill-w: 36px;
    --pill-h: 20px;
    --pill-pad: 2px;
    --thumb: calc(var(--pill-h) - (var(--pill-pad) * 2));
    --travel: calc(var(--pill-w) - var(--thumb) - (var(--pill-pad) * 2));

    position: relative;
    width: var(--pill-w);
    height: var(--pill-h);
    padding: 0;
    border-radius: 9999px;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: background-color var(--duration-fast) ease, border-color var(--duration-fast) ease;
    flex-shrink: 0;
  }
  .theme-pill:hover { border-color: var(--accent); }
  .theme-pill:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .theme-pill-thumb {
    position: absolute;
    top: var(--pill-pad);
    left: var(--pill-pad);
    width: var(--thumb);
    height: var(--thumb);
    border-radius: 9999px;
    background: var(--fg);
    box-shadow: 0 1px 2px color-mix(in oklab, black 22%, transparent);
    transform: translateX(0);
    transition: transform 220ms var(--ease-out-expo);
  }

  :global([data-theme="dark"]) .theme-pill {
    background: var(--accent);
    border-color: var(--accent);
  }
  :global([data-theme="dark"]) .theme-pill-thumb {
    transform: translateX(var(--travel));
    background: var(--bg);
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-pill-thumb { transition: none; }
  }
</style>

<script>
  function setupThemeToggle() {
    const root = document.documentElement;

    const syncAllPills = () => {
      const isDark = root.dataset.theme === 'dark';
      document.querySelectorAll('.theme-pill').forEach((pill) => {
        pill.setAttribute('aria-checked', String(isDark));
      });
    };

    const applyTheme = (next: 'light' | 'dark') => {
      root.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (_) {}
      syncAllPills();
      window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: next } }));
    };

    document.querySelectorAll('.theme-switch').forEach((wrap) => {
      const pill = wrap.querySelector('.theme-pill');
      if (!pill || pill.dataset.bound === '1') return;
      pill.dataset.bound = '1';
      pill.addEventListener('click', () => {
        applyTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
      });
    });

    document.querySelectorAll<HTMLButtonElement>('[data-theme-set]').forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const next = btn.dataset.themeSet as 'light' | 'dark' | undefined;
        if (next === 'light' || next === 'dark') applyTheme(next);
      });
    });

    syncAllPills();
  }
  setupThemeToggle();
  document.addEventListener('astro:page-load', setupThemeToggle);
</script>
