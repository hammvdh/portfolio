---
import { getCollection } from 'astro:content';

const all = await getCollection('projects', ({ data }) => data.featured);
const projects = all.sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const categoryLabels: Record<string, string> = {
  healthcare: 'Healthcare',
  saas: 'SaaS',
  islamic: 'Islamic',
  research: 'Research',
  design: 'Design',
};

const statusLabels: Record<string, string> = {
  live: 'Live',
  building: 'Building',
  archived: 'Archived',
  thesis: 'Thesis',
};

function targetFor(p: (typeof projects)[number]) {
  if (p.data.caseStudy) {
    return { href: `/work/${p.slug}`, external: false };
  }
  const ext =
    p.data.links?.live ?? p.data.links?.repo ?? p.data.links?.external;
  return { href: ext ?? `/work/${p.slug}`, external: !!ext };
}
---

<section class="section reveal-on-scroll" id="work" aria-labelledby="work-heading">
  <div class="container-page">
    <header class="section-head">
      <h2 id="work-heading" class="section-title">Selected Work</h2>
    </header>

    <div class="work-grid">
      {projects.map((p) => {
        const { href, external } = targetFor(p);
        return (
          <a
            href={href}
            class="card"
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            data-astro-prefetch={!external}
          >
            <div class="card-image">
              {p.data.image && (
                <img src={p.data.image} alt={p.data.title} loading="lazy" decoding="async" />
              )}
            </div>
            <div class="card-meta">
              <span class="meta-left">
                <span>{p.data.year}</span>
                <span aria-hidden="true">·</span>
                <span>{categoryLabels[p.data.category] ?? p.data.category}</span>
              </span>
              <span class="status" data-status={p.data.status}>{statusLabels[p.data.status]}</span>
            </div>
            <h3 class="card-title">
              {p.data.title}
              <svg class="card-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {external ? (
                  <Fragment>
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </Fragment>
                ) : (
                  <Fragment>
                    <path d="M5 12h14" />
                    <path d="m12 5 7 7-7 7" />
                  </Fragment>
                )}
              </svg>
            </h3>
            <p class="card-summary">{p.data.summary}</p>
          </a>
        );
      })}
    </div>
  </div>
</section>

<style>
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--gap-block-mobile);
  }
  @media (min-width: 640px) {
    .section-head { margin-bottom: var(--gap-block-desktop); }
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin: 0;
  }
  @media (min-width: 640px) {
    .section-title { font-size: 1.75rem; }
  }

  .work-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .work-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.75rem 1.25rem;
    }
  }

  .card {
    display: block;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg-elevated);
    padding: 0.75rem;
    transition: border-color var(--duration-normal) ease, transform var(--duration-normal) ease;
    color: inherit;
  }
  .card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .card:hover .card-image img {
    transform: scale(1.02);
  }

  .card-image {
    aspect-ratio: 16 / 10;
    background: var(--bg);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 0.85rem;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out-expo);
  }

  .card-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--fg-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .meta-left {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    min-width: 0;
  }
  .card-meta .status {
    color: var(--accent);
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .card-meta .status::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 3px color-mix(in oklab, currentColor 18%, transparent);
  }
  .card-meta .status[data-status="archived"],
  .card-meta .status[data-status="thesis"] {
    color: var(--fg-subtle);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0 0 0.35rem;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  .card-icon {
    color: var(--fg-subtle);
    transition: transform var(--duration-normal) ease, color var(--duration-fast) ease;
  }
  .card:hover .card-icon {
    color: var(--accent);
    transform: translate(2px, -2px);
  }

  .card-summary {
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: var(--leading-body);
    margin: 0;
  }
</style>
