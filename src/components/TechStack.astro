---
import { techStack } from '../data/techStack.ts';
const groups = Object.entries(techStack);
---

<section class="section reveal-on-scroll" id="tech" aria-labelledby="tech-heading">
  <div class="container-page">
    <header class="section-head">
      <h2 id="tech-heading" class="section-title">Tech Stack</h2>
    </header>

    <div class="groups">
      {groups.map(([category, techs]) => (
        <div class="group">
          <p class="caption">{category}</p>
          <ul class="pills">
            {techs.map((t) => <li class="pill">{t}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    margin-bottom: var(--gap-block-mobile);
  }
  @media (min-width: 640px) {
    .section-head { margin-bottom: var(--gap-block-desktop); }
  }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg);
    margin: 0;
  }
  @media (min-width: 640px) {
    .section-title { font-size: 1.75rem; }
  }

  .groups {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .group { display: flex; flex-direction: column; gap: 0.5rem; }

  .caption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
    margin: 0;
  }

  .pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .pill {
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 0.3rem 0.7rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease;
    cursor: default;
  }
  .pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
