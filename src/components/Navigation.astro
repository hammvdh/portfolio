---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;
const isActive = (path: string) =>
  path === '/' ? pathname === '/' : pathname.startsWith(path);

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Writing' },
];
---

<header class="site-nav-shell">
  <nav class="site-nav container-page" aria-label="Primary">
    <a href="/" class="brand-mark" aria-label="Hammadh Arquil — Home" data-astro-prefetch>
      <svg viewBox="0 0 1282.84 900" fill="currentColor" aria-hidden="true">
        <polygon points="441.42 400 441.42 700 1182.84 700 1282.84 600 1141.42 600 1141.42 0 500 0 400 100 1041.42 100 1041.42 600 541.42 600 541.42 500 941.41 500 941.41 200 300 200 0 500 241.42 500 241.42 900 982.84 900 1082.84 800 341.42 800 341.42 400 241.42 400 341.42 300 841.41 300 841.41 400 441.42 400" />
      </svg>
    </a>

    <div class="desktop-links">
      {navLinks.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', isActive(l.href) && 'is-active']}
          data-astro-prefetch
        >
          {l.label}
        </a>
      ))}
      <span class="divider" aria-hidden="true"></span>
      <ThemeToggle />
    </div>

    <div class="mobile-controls">
      <button
        id="menu-open"
        type="button"
        class="icon-btn"
        aria-label="Open menu"
        aria-controls="mobile-drawer"
        aria-expanded="false"
      >
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" x2="20" y1="6" y2="6" />
          <line x1="4" x2="20" y1="12" y2="12" />
          <line x1="4" x2="20" y1="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>
</header>

<div
  id="mobile-backdrop"
  class="drawer-backdrop"
  aria-hidden="true"
  data-state="closed"
></div>

<aside
  id="mobile-drawer"
  class="drawer"
  data-state="closed"
  aria-hidden="true"
  aria-label="Site menu"
>
  <div class="drawer-head">
    <span class="drawer-title">Menu</span>
    <button id="menu-close" type="button" class="icon-btn" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="drawer-nav" aria-label="Mobile primary">
    {navLinks.map((l) => (
      <a
        href={l.href}
        class:list={['drawer-link', isActive(l.href) && 'is-active']}
        data-astro-prefetch
      >
        {l.label}
      </a>
    ))}
  </nav>

  <hr />

  <nav class="drawer-more" aria-label="More pages">
    <a href="/now" data-astro-prefetch>/now</a>
    <span aria-hidden="true">·</span>
    <a href="/uses" data-astro-prefetch>/uses</a>
    <span aria-hidden="true">·</span>
    <a href="/resume" data-astro-prefetch>/resume</a>
    <span aria-hidden="true">·</span>
    <a href="/rss.xml">/rss</a>
  </nav>

  <hr />

  <div class="drawer-row">
    <ThemeToggle />
    <span class="drawer-row-label">Theme</span>
  </div>

  <hr />

  <div class="drawer-socials" aria-label="Social links">
    <a href="https://github.com/hammvdh" target="_blank" rel="noopener noreferrer" aria-label="GitHub">GitHub</a>
    <a href="https://x.com/hammvdh" target="_blank" rel="noopener noreferrer" aria-label="X">X</a>
    <a href="https://www.linkedin.com/in/hammadharquil/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
  </div>
</aside>

<style>
  .site-nav-shell {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in oklab, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    border-bottom: 1px solid transparent;
    transition: border-color var(--duration-normal) ease,
                background-color var(--duration-normal) ease;
  }
  .site-nav-shell.is-scrolled {
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    border-bottom-color: var(--border);
  }
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .site-nav-shell { background: var(--bg); }
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
    position: relative;
  }
  @media (min-width: 640px) {
    .site-nav {
      padding-block: 1.25rem;
    }
  }

  .brand-mark {
    color: var(--accent);
    display: inline-flex;
    transition: color var(--duration-fast) ease, opacity var(--duration-fast) ease;
  }
  .brand-mark:hover { opacity: 0.85; }
  .brand-mark svg {
    height: 1.75rem;
    width: auto;
  }

  .desktop-links {
    display: none;
    align-items: center;
    gap: 1.25rem;
    font-size: 0.875rem;
  }
  @media (min-width: 640px) {
    .desktop-links { display: inline-flex; }
  }
  .nav-link {
    color: var(--fg-muted);
    font-weight: 500;
    transition: color var(--duration-fast) ease;
  }
  .nav-link:hover { color: var(--accent); }
  .nav-link.is-active { color: var(--accent); }
  .desktop-links .divider {
    width: 1px;
    height: 1.25rem;
    background: var(--border);
  }

  .mobile-controls {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  @media (min-width: 640px) {
    .mobile-controls { display: none; }
  }
  .icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    color: var(--fg-muted);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color var(--duration-fast) ease, background-color var(--duration-fast) ease;
  }
  .icon-btn:hover {
    color: var(--accent);
    background: var(--bg-elevated);
  }

  /* Drawer */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: color-mix(in oklab, var(--bg) 60%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 200ms ease;
    z-index: 60;
  }
  .drawer-backdrop[data-state="open"] {
    opacity: 1;
    pointer-events: auto;
  }

  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    height: 100dvh;
    width: min(280px, 80vw);
    background: var(--bg);
    border-left: 1px solid var(--border);
    transform: translateX(100%);
    transition: transform 220ms var(--ease-out-expo);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    z-index: 70;
    overflow-y: auto;
  }
  .drawer[data-state="open"] {
    transform: translateX(0);
  }

  .drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.5rem;
  }
  .drawer-title {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
  }

  .drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .drawer-link {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--fg-muted);
    transition: color var(--duration-fast) ease;
  }
  .drawer-link:hover,
  .drawer-link.is-active {
    color: var(--accent);
  }

  .drawer hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0.25rem 0;
  }

  .drawer-more {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-subtle);
  }
  .drawer-more a {
    color: var(--fg-subtle);
    transition: color var(--duration-fast) ease;
  }
  .drawer-more a:hover { color: var(--accent); }

  .drawer-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .drawer-row-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
  }

  .drawer-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
  }
  .drawer-socials a:hover { color: var(--accent); }
</style>

<script>
  function setupDrawer() {
    const openBtn = document.getElementById('menu-open');
    const closeBtn = document.getElementById('menu-close');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('mobile-backdrop');
    const main = document.getElementById('main');
    if (!openBtn || !drawer || !backdrop) return;
    if ((openBtn as HTMLElement).dataset.bound === '1') return;
    (openBtn as HTMLElement).dataset.bound = '1';

    let lastFocused: HTMLElement | null = null;

    const openDrawer = () => {
      lastFocused = document.activeElement as HTMLElement;
      drawer.dataset.state = 'open';
      backdrop.dataset.state = 'open';
      drawer.setAttribute('aria-hidden', 'false');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      if (main) main.setAttribute('inert', '');
      const firstLink = drawer.querySelector('a, button') as HTMLElement | null;
      firstLink?.focus();
    };

    const closeDrawer = () => {
      drawer.dataset.state = 'closed';
      backdrop.dataset.state = 'closed';
      drawer.setAttribute('aria-hidden', 'true');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      if (main) main.removeAttribute('inert');
      lastFocused?.focus();
    };

    openBtn.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);
    drawer.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => closeDrawer())
    );

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && drawer.dataset.state === 'open') {
        closeDrawer();
      }
    });
  }
  setupDrawer();
  document.addEventListener('astro:page-load', setupDrawer);

  function applyNavScrollState() {
    const shell = document.querySelector('.site-nav-shell');
    if (!shell) return;
    shell.classList.toggle('is-scrolled', window.scrollY > 4);
  }
  if (!(window as unknown as { __navScrollBound?: boolean }).__navScrollBound) {
    (window as unknown as { __navScrollBound?: boolean }).__navScrollBound = true;
    window.addEventListener('scroll', applyNavScrollState, { passive: true });
  }
  applyNavScrollState();
  document.addEventListener('astro:page-load', applyNavScrollState);
</script>
