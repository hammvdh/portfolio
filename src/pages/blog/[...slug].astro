---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { Content } = await post.render();
const data = post.data;

const body = post.body ?? '';
const words = body.trim().split(/\s+/).length;
const readingMin = Math.max(1, Math.round(words / 225));

const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const idx = all.findIndex((p) => p.slug === post.slug);
const prev = idx < all.length - 1 ? all[idx + 1] : null;
const next = idx > 0 ? all[idx - 1] : null;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<Layout
  title={`${data.title} — Hammadh Arquil`}
  description={data.description}
  image={data.heroImage}
  type="article"
  publishedDate={data.pubDate}
  updatedDate={data.updatedDate}
  tags={data.tags}
>
  <article class="post">
    <header class="container-page post-head">
      <a href="/blog" class="back-link" data-astro-prefetch>← All writing</a>
      <h1>{data.title}</h1>
      <p class="post-meta">
        <time datetime={data.pubDate.toISOString()}>{fmtDate(data.pubDate)}</time>
        <span aria-hidden="true">·</span>
        <span>{readingMin} min read</span>
        {data.updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Updated {fmtDate(data.updatedDate)}</span>
          </>
        )}
      </p>
      {data.tags.length > 0 && (
        <ul class="post-tags">
          {data.tags.map((t) => (
            <li><a href={`/blog/tags/${t}`}>#{t}</a></li>
          ))}
        </ul>
      )}
    </header>

    <div class="container-page prose body">
      <Content />
    </div>

    <footer class="container-page post-foot">
      <p class="rss-cta">
        Liked this? <a href="/rss.xml">Subscribe via RSS</a> or
        <a href="https://x.com/hammvdh" target="_blank" rel="noopener noreferrer">find me on X</a>.
      </p>

      {(prev || next) && (
        <nav class="related" aria-label="Related posts">
          {prev && (
            <a class="related-link prev" href={`/blog/${prev.slug}/`} data-astro-prefetch>
              <span class="caption">← Older</span>
              <span class="title">{prev.data.title}</span>
            </a>
          )}
          {next && (
            <a class="related-link next" href={`/blog/${next.slug}/`} data-astro-prefetch>
              <span class="caption">Newer →</span>
              <span class="title">{next.data.title}</span>
            </a>
          )}
        </nav>
      )}
    </footer>
  </article>
</Layout>

<style>
  .post {
    padding-top: 2rem;
    padding-bottom: 4rem;
  }
  @media (min-width: 640px) {
    .post { padding-top: 3rem; }
  }
  .post-head { margin-bottom: 2rem; }
  .back-link {
    display: inline-block;
    color: var(--fg-muted);
    font-size: 0.85rem;
    margin-bottom: 1.25rem;
    transition: color var(--duration-fast) ease;
  }
  .back-link:hover { color: var(--accent); }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    line-height: var(--leading-display);
    letter-spacing: -0.025em;
    color: var(--fg);
    margin: 0;
  }
  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-subtle);
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 1rem 0 0;
  }
  .post-tags {
    list-style: none;
    margin: 0.85rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .post-tags a {
    border: 1px solid var(--border);
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg-muted);
    transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease;
  }
  .post-tags a:hover { border-color: var(--accent); color: var(--accent); }

  .body { margin-top: 2rem; }

  .post-foot {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .rss-cta {
    color: var(--fg-muted);
    font-size: 0.9rem;
    margin: 0 0 2rem;
  }
  .rss-cta a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .related {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) {
    .related { grid-template-columns: 1fr 1fr; }
  }
  .related-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg);
    transition: border-color var(--duration-fast) ease, color var(--duration-fast) ease;
  }
  .related-link.next { text-align: right; }
  .related-link:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .related-link .caption {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg-subtle);
  }
  .related-link .title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.95rem;
  }
</style>
