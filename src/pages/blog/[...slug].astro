---
import { type CollectionEntry, getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<Layout title={post.data.title}>
	<div id="blog-post-page">
		<a href="/blog/" class="retro-back-link">
			← Back to writing
		</a>

		<article>
			<header class="retro-article-header">
				<h1 class="retro-page-h1" style="margin-bottom: 4px;">{post.data.title}</h1>
				<div class="retro-article-meta">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
					</time>
					<span>•</span>
					<span>Article</span>
				</div>
			</header>

			<div class="retro-prose">
				<Content />
			</div>
		</article>

		<p class="retro-footer" style="margin-top: 2rem; padding-top: 12px; border-top: 2px groove #d4d0c8;">
			© 2026 Hammadh Arquil. All rights reserved.
		</p>
	</div>
</Layout>
