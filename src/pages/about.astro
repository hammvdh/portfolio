---
import Layout from '../layouts/Layout.astro';
import Experience from '../components/Experience';
import TechStack from '../components/TechStack';
---

<Layout title="About | Hammadh Arquil">
	<div id="about-page">
		<h1 class="retro-page-h1">About me</h1>

		<div class="retro-about-grid">
			<div class="retro-about-photo" role="img" aria-label="Portrait"></div>
			<div class="retro-about-copy">
				<p>
					Hey, I'm <strong>Hammadh Arquil</strong>, a software engineer and product designer based in Colombo, Sri Lanka.
				</p>
				<p>
					My journey started back in 2016 as a graphic designer under the alias <em>ElitePSD</em>. I've always been obsessed
					with how things look and feel. Transitioning into engineering felt natural—it allowed me to bring my designs to life
					and build systems that actually work.
				</p>
				<p>
					I currently work at <strong>HTWorks</strong>, building telemedicine solutions that directly impact patient care. I
					previously explored the bleeding edge of AI as a Founding Engineer at <strong>Suno Analytics</strong>, and continue
					building for my community with <strong>Prayr</strong>.
				</p>
				<p>
					When I'm not coding, you can find me exploring new design trends, contributing to open source, or just enjoying a good
					cup of tea while pondering the next big idea.
				</p>
			</div>
		</div>

		<div class="mb-12">
			<Experience client:load />
		</div>

		<div class="mb-12">
			<TechStack client:load />
		</div>

		<p class="retro-footer">© 2026 Hammadh Arquil. All rights reserved.</p>
	</div>
</Layout>
